{
    "version": "1.0",
    "skills": {
        "jj-diffs": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Examine changes, review diffs, resolve conflicts in jj repos",
            "promptTriggers": {
                "keywords": [
                    "jj",
                    "jujutsu",
                    "examine changes",
                    "jj status",
                    "jj diff",
                    "jj log",
                    "resolve conflict",
                    "change id",
                    "trunk()"
                ],
                "intentPatterns": [
                    "(examine|review|check|look at).*?(change|diff|what.*changed)",
                    "(prepare|create|write|make).*?(commit|description)",
                    "(resolve|fix).*?conflict"
                ]
            }
        },
        "jj-management": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Split, squash, move changes between jj revisions, group into logical changesets, describe commits",
            "promptTriggers": {
                "keywords": [
                    "split",
                    "squash",
                    "changeset",
                    "describe",
                    "wip",
                    "jj new",
                    "group changes",
                    "move changes",
                    "organize changes"
                ],
                "intentPatterns": [
                    "(split|squash|move|group|organize).*?(change|commit|file|revision|changeset)",
                    "(create|make|write).*?(commit|changeset|description)",
                    "wip.*?(prefix|name|describe)"
                ]
            }
        },
        "drizzle-migrations": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Database schema changes, migrations, and conflict resolution",
            "promptTriggers": {
                "keywords": [
                    "migration",
                    "drizzle",
                    "schema change",
                    "generate migration",
                    "journal",
                    "snapshot",
                    "backfill",
                    "schema drift",
                    "enum",
                    "foreign key"
                ],
                "intentPatterns": [
                    "(add|modify|change|update|alter).*?(schema|column|table|enum|index)",
                    "(migration|migrate).*?(conflict|error|fail)",
                    "(generate|run|push).*?migration"
                ]
            }
        },
        "writing-plans": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Create plans with proper naming, format, and file locations",
            "promptTriggers": {
                "keywords": [
                    "write a plan",
                    "create a plan",
                    "plan this",
                    "planning",
                    "plan mode"
                ],
                "intentPatterns": [
                    "(write|create|make|draft).*?plan",
                    "plan.*?(feature|task|work|implementation)"
                ]
            }
        },
        "managing-plans": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Manage plan lifecycle: move between statuses, track progress, rename files, list plans",
            "promptTriggers": {
                "keywords": [
                    "plan status",
                    "move plan",
                    "plan progress",
                    "plan list",
                    "backlog",
                    "rename plan",
                    "archive plan"
                ],
                "intentPatterns": [
                    "move.*?plan.*(todo|active|done|backlog|draft|archived)",
                    "(check|update|track).*?plan.*(status|progress)",
                    "(list|show).*?plan",
                    "(rename|archive|complete).*?plan"
                ]
            }
        },
        "writing-recipes": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Format recipes in markdown with correct ingredient syntax",
            "promptTriggers": {
                "keywords": [
                    "recipe",
                    "cooking",
                    "ingredient",
                    "convert recipe",
                    "recipe format"
                ],
                "intentPatterns": [
                    "(add|create|write|format|convert).*?recipe",
                    "recipe.*?(url|link|site|from)"
                ]
            }
        },
        "writing-memories": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Save learnings to memory files after complex tasks or recurring patterns",
            "promptTriggers": {
                "keywords": [
                    "save learning",
                    "write memory",
                    "remember this",
                    "save to memory",
                    "add to memory",
                    "document this pattern",
                    "save pattern"
                ],
                "intentPatterns": [
                    "(save|write|add|store|document).*(learn|memory|pattern|preference)",
                    "remember.*(this|across|next|session)"
                ]
            }
        },
        "query-logs-production": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Query Vercel production logs — ONLY when user explicitly says production/prod/live/vercel",
            "promptTriggers": {
                "keywords": [
                    "production logs",
                    "prod logs",
                    "vercel logs",
                    "production error",
                    "prod error",
                    "live error",
                    "live traffic"
                ],
                "intentPatterns": [
                    "(production|prod|live|vercel).*?(log|error|issue)",
                    "(check|query|investigate).*?(production|prod|live|vercel)"
                ]
            }
        },
        "query-db-production": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Query production read replica — ONLY when user explicitly says production/prod/live",
            "promptTriggers": {
                "keywords": [
                    "production data",
                    "prod database",
                    "prod data",
                    "query production",
                    "live data",
                    "read replica",
                    "check prod"
                ],
                "intentPatterns": [
                    "(production|prod|live).*?(data|database|db|issue|bug)",
                    "(investigate|check|query).*?(production|prod|live)",
                    "(read replica|read-replica).*?(query|check)"
                ]
            }
        },
        "query-logs-development": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Query local development logs for debugging and verifying changes",
            "promptTriggers": {
                "keywords": [
                    "dev logs",
                    "check logs",
                    "development error",
                    "dev server",
                    "local error",
                    "console output",
                    "check dev",
                    "verify changes",
                    "compilation error",
                    "check for errors"
                ],
                "intentPatterns": [
                    "(check|query|search|look at).*?(dev|local|development).*?(log|error|output)",
                    "(dev|local|development).*?(log|error|server|output)",
                    "(verify|check|confirm).*?(change|work|fix)",
                    "(compilation|runtime|server).*?error"
                ]
            }
        },
        "browser-dev": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Playwright MCP browser automation for verifying UI changes and debugging client-side issues",
            "promptTriggers": {
                "keywords": [
                    "browser",
                    "UI check",
                    "client error",
                    "console error",
                    "screenshot",
                    "visual check",
                    "network request",
                    "does it look",
                    "render",
                    "hydration"
                ],
                "intentPatterns": [
                    "(check|verify|test).*?(browser|UI|visual|render|client)",
                    "(screenshot|console|network).*?(error|log|request)",
                    "does.*(look|render|display|show)"
                ]
            }
        },
        "lint-conventions": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Fast convention check for legal-marketplace: naming, layers, style",
            "promptTriggers": {
                "keywords": [
                    "review changes",
                    "check conventions",
                    "lint conventions",
                    "convention check",
                    "code review"
                ],
                "intentPatterns": [
                    "(review|check|verify|lint).*?(conventions|standards|naming|architecture)",
                    "(check|review).*?(code|changes).*?(conventions|standards)"
                ]
            }
        },
        "managing-notes": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Note creation, renaming, restructuring in Obsidian vault",
            "promptTriggers": {
                "keywords": [
                    "create a note",
                    "new note",
                    "rename note",
                    "knowledgebase",
                    "knowledge base",
                    "restructure note",
                    "note format",
                    "note convention",
                    "obsidian"
                ],
                "intentPatterns": [
                    "(create|make|add|write|start).*?note",
                    "(rename|move|restructure|reorganize).*?(note|file)",
                    "(knowledgebase|knowledge base).*?(create|update|add|format)",
                    "(what|which).*?(prefix|category|naming).*?(note|file)",
                    "(event|recipe|travel|todo).*?file"
                ]
            }
        },
        "writing-code-quick": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "low",
            "description": "Trivial fixes: typos, formatting, single-line changes",
            "promptTriggers": {
                "keywords": [
                    "typo",
                    "quick fix",
                    "minor fix",
                    "small fix",
                    "formatting issue",
                    "rename variable"
                ],
                "intentPatterns": [
                    "(fix|correct).*(typo|spelling|formatting)",
                    "(rename|change).*(variable|function|method).*name"
                ]
            }
        }
    }
}
