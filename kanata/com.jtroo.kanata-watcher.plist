<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Keyboard watcher — runs as user LaunchAgent for TCC/Input Monitoring access.
  Touches /tmp/kanata-restart-trigger when a keyboard is connected/disconnected.
  The kanata-restarter LaunchDaemon (root) watches that file and restarts kanata.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jtroo.kanata-watcher</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/kanata-watcher</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/marc.deferranti/Library/Logs/kanata-watcher.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/marc.deferranti/Library/Logs/kanata-watcher.log</string>
</dict>
</plist>
