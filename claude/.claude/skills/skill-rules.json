{
    "version": "1.0",
    "skills": {
        "jj-examine": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Examine changes, prepare commits, resolve conflicts in jj repos",
            "promptTriggers": {
                "keywords": [
                    "jj",
                    "jujutsu",
                    "examine changes",
                    "jj status",
                    "jj diff",
                    "jj log",
                    "resolve conflict",
                    "change id",
                    "trunk()"
                ],
                "intentPatterns": [
                    "(examine|review|check|look at).*?(change|diff|what.*changed)",
                    "(prepare|create|write|make).*?(commit|description)",
                    "(resolve|fix).*?conflict"
                ]
            }
        },
        "drizzle-migrations": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Database schema changes, migrations, and conflict resolution",
            "promptTriggers": {
                "keywords": [
                    "migration",
                    "drizzle",
                    "schema change",
                    "generate migration",
                    "journal",
                    "snapshot",
                    "backfill",
                    "schema drift",
                    "enum",
                    "foreign key"
                ],
                "intentPatterns": [
                    "(add|modify|change|update|alter).*?(schema|column|table|enum|index)",
                    "(migration|migrate).*?(conflict|error|fail)",
                    "(generate|run|push).*?migration"
                ]
            }
        },
        "github-commits-and-prs": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Create git commits and GitHub PRs with proper conventions",
            "promptTriggers": {
                "keywords": [
                    "pull request",
                    "create pr",
                    "open pr",
                    "release notes",
                    "amend commit"
                ],
                "intentPatterns": [
                    "(create|open|make|write).*?(pull request|PR)",
                    "(write|create|draft).*?release note"
                ]
            }
        },
        "github-examining-changes": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "Examine branch changes before committing or creating PRs",
            "promptTriggers": {
                "keywords": [
                    "what changed",
                    "review changes",
                    "before committing",
                    "before creating pr",
                    "unintended changes"
                ],
                "intentPatterns": [
                    "(what|which).*(changed|modified|different)",
                    "(check|verify|review).*?(before|prior to).*(commit|push|pr)"
                ]
            }
        },
        "writing-sql-scripts": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Write SQL scripts with verification and execution sections",
            "promptTriggers": {
                "keywords": [
                    "sql script",
                    "write sql",
                    "database query",
                    "fix data",
                    "update records",
                    "ad-hoc query",
                    "backfill data",
                    "data migration"
                ],
                "intentPatterns": [
                    "(write|create|run).*?sql",
                    "(fix|update|insert|delete|backfill).*?(record|row|data)",
                    "(query|script).*?database"
                ]
            }
        },
        "writing-plans": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Create plans with proper naming, format, and file locations",
            "promptTriggers": {
                "keywords": [
                    "write a plan",
                    "create a plan",
                    "plan this",
                    "planning",
                    "plan mode"
                ],
                "intentPatterns": [
                    "(write|create|make|draft).*?plan",
                    "plan.*?(feature|task|work|implementation)"
                ]
            }
        },
        "managing-plans": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Manage plan lifecycle: move between statuses, track progress, rename files, list plans",
            "promptTriggers": {
                "keywords": [
                    "plan status",
                    "move plan",
                    "plan progress",
                    "plan list",
                    "backlog",
                    "rename plan",
                    "archive plan"
                ],
                "intentPatterns": [
                    "move.*?plan.*(todo|active|done|backlog|draft|archived)",
                    "(check|update|track).*?plan.*(status|progress)",
                    "(list|show).*?plan",
                    "(rename|archive|complete).*?plan"
                ]
            }
        },
        "writing-recipes": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Format recipes in markdown with correct ingredient syntax",
            "promptTriggers": {
                "keywords": [
                    "recipe",
                    "cooking",
                    "ingredient",
                    "convert recipe",
                    "recipe format"
                ],
                "intentPatterns": [
                    "(add|create|write|format|convert).*?recipe",
                    "recipe.*?(url|link|site|from)"
                ]
            }
        },
        "writing-memories": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Save learnings to memory files after complex tasks or recurring patterns",
            "promptTriggers": {
                "keywords": [
                    "save learning",
                    "write memory",
                    "remember this",
                    "save to memory",
                    "add to memory",
                    "document this pattern",
                    "save pattern"
                ],
                "intentPatterns": [
                    "(save|write|add|store|document).*(learn|memory|pattern|preference)",
                    "remember.*(this|across|next|session)"
                ]
            }
        },
        "query-logs-production": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Query Vercel production logs — ONLY when user explicitly says production/prod/live/vercel",
            "promptTriggers": {
                "keywords": [
                    "production logs",
                    "prod logs",
                    "vercel logs",
                    "production error",
                    "prod error",
                    "live error",
                    "live traffic"
                ],
                "intentPatterns": [
                    "(production|prod|live|vercel).*?(log|error|issue)",
                    "(check|query|investigate).*?(production|prod|live|vercel)"
                ]
            }
        },
        "query-db-production": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Query production read replica — ONLY when user explicitly says production/prod/live",
            "promptTriggers": {
                "keywords": [
                    "production data",
                    "prod database",
                    "prod data",
                    "query production",
                    "live data",
                    "read replica",
                    "check prod"
                ],
                "intentPatterns": [
                    "(production|prod|live).*?(data|database|db|issue|bug)",
                    "(investigate|check|query).*?(production|prod|live)",
                    "(read replica|read-replica).*?(query|check)"
                ]
            }
        },
        "query-logs-development": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Query local development logs for debugging and verifying changes",
            "promptTriggers": {
                "keywords": [
                    "dev logs",
                    "check logs",
                    "development error",
                    "dev server",
                    "local error",
                    "console output",
                    "check dev",
                    "verify changes",
                    "compilation error",
                    "check for errors"
                ],
                "intentPatterns": [
                    "(check|query|search|look at).*?(dev|local|development).*?(log|error|output)",
                    "(dev|local|development).*?(log|error|server|output)",
                    "(verify|check|confirm).*?(change|work|fix)",
                    "(compilation|runtime|server).*?error"
                ]
            }
        },
        "browser-dev": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Playwright MCP browser automation for verifying UI changes and debugging client-side issues",
            "promptTriggers": {
                "keywords": [
                    "browser",
                    "UI check",
                    "client error",
                    "console error",
                    "screenshot",
                    "visual check",
                    "network request",
                    "does it look",
                    "render",
                    "hydration"
                ],
                "intentPatterns": [
                    "(check|verify|test).*?(browser|UI|visual|render|client)",
                    "(screenshot|console|network).*?(error|log|request)",
                    "does.*(look|render|display|show)"
                ]
            }
        },
        "writing-code-quick": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "low",
            "description": "Trivial fixes: typos, formatting, single-line changes",
            "promptTriggers": {
                "keywords": [
                    "typo",
                    "quick fix",
                    "minor fix",
                    "small fix",
                    "formatting issue",
                    "rename variable"
                ],
                "intentPatterns": [
                    "(fix|correct).*(typo|spelling|formatting)",
                    "(rename|change).*(variable|function|method).*name"
                ]
            }
        }
    }
}
