;; Universal Scroll Bindings
;;
;; Scroll up/down: handled by the ctrl layer in layers.kbd
;;   A (hold) + u  →  Page Up    (nvim: remapped to <C-u> half-page)
;;   A (hold) + d  →  Page Down  (nvim: remapped to <C-d> half-page)
;;
;; Top/bottom of page (active while Caps Lock / hyper is held):
;;   g           →  Home  (top)
;;   f (shift)+g →  End   (bottom)

(defalias
  scroll-top (unmod home)
  scroll-bottom (unmod end)
  scroll-goto (fork @scroll-top @scroll-bottom (lsft))
)
