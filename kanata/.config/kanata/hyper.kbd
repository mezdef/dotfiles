;; Hyper Key
;;
;; Caps Lock → ctrl+opt+cmd held, escape tapped
;;
;; Uses tap-hold-press with generous hold timeout. The hold activates
;; immediately when another key is pressed (tap-hold-press), so the
;; 200ms hold timeout only matters for solo caps holds.

(defalias
  hyper (tap-hold-press 300 200 esc (multi lctl lalt lmet))
)
