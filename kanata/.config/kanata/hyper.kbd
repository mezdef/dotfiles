;; Hyper Key
;;
;; Caps Lock → ctrl+opt+cmd held, escape tapped
;;
;; tap-hold-press 300 200:
;;   300ms = tap timeout (max hold before it becomes a hold action)
;;   200ms = hold timeout (ignored here — tap-hold-press activates hold
;;           immediately when another key is pressed, so this only
;;           matters if caps is held alone without pressing anything)

(defalias
  hyper (tap-hold-press 300 200 esc (multi lctl lalt lmet (layer-while-held hyper)))
)
