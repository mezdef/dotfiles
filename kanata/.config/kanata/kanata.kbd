;; Kanata configuration
;; See individual files for details.

(defcfg
  process-unmapped-keys yes
  log-layer-changes no
  concurrent-tap-hold yes ;; allow multiple home row mods held simultaneously
)

;; 102d (ISO non-US backslash) included in defsrc so kanata can
;; remap it to grv (backtick) — fixes Karabiner virtual HID ISO quirk
(defsrc
  caps grv 102d
)

(include hyper.kbd)
(include home-row-mods.kbd)
